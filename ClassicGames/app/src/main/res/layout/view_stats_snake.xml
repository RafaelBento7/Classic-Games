<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/Stats_Hint_Prev"
                style="@style/TextView"
                android:text="@string/swipe_right"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/Stats_Hint_Next"
                style="@style/TextView"
                android:text="@string/swipe_left"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/Stats_Snake_Title"
                style="@style/TitleTextView"
                android:layout_marginTop="20dp"
                android:text="@string/snake_game"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/Stats_Hint_Next" />

            <ImageView
                android:id="@+id/Stats_Snake_Image"
                style="@style/ImageButton_Games"
                android:contentDescription="@string/snake_game"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/Stats_Snake_Title"
                app:srcCompat="@drawable/snake" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="50dp"
                app:layout_constraintTop_toBottomOf="@+id/Stats_Snake_Image">

                <!-- Overall -->
                <TextView style="@style/Stats_SectionHeader" android:text="@string/stat_overall" />
                <View style="@style/Stats_SectionDivider" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">
                    <TableRow>
                        <TextView style="@style/TextView" android:text="@string/stat_games_played" />
                        <TextView android:id="@+id/Stats_Snake_Games" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_total_points" />
                        <TextView android:id="@+id/Stats_Snake_TotalPoints" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_apples_eaten" />
                        <TextView android:id="@+id/Stats_Snake_ApplesEaten" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_golden_apples_eaten" />
                        <TextView android:id="@+id/Stats_Snake_GoldenEaten" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                </TableLayout>

                <!-- Small map -->
                <TextView style="@style/Stats_SectionHeader" android:text="@string/leaderboard_snake_small_map" />
                <View style="@style/Stats_SectionDivider" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">
                    <TableRow>
                        <TextView style="@style/TextView" android:text="@string/stat_best_score" />
                        <TextView android:id="@+id/Stats_Snake_SmallRecord" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_no_obstacles" />
                        <TextView android:id="@+id/Stats_Snake_SmallPlain" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_obstacles" />
                        <TextView android:id="@+id/Stats_Snake_SmallObstacles" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                </TableLayout>

                <!-- Medium map -->
                <TextView style="@style/Stats_SectionHeader" android:text="@string/leaderboard_snake_medium_map" />
                <View style="@style/Stats_SectionDivider" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">
                    <TableRow>
                        <TextView style="@style/TextView" android:text="@string/stat_best_score" />
                        <TextView android:id="@+id/Stats_Snake_MediumRecord" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_no_obstacles" />
                        <TextView android:id="@+id/Stats_Snake_MediumPlain" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_obstacles" />
                        <TextView android:id="@+id/Stats_Snake_MediumObstacles" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                </TableLayout>

                <!-- Big map -->
                <TextView style="@style/Stats_SectionHeader" android:text="@string/leaderboard_snake_big_map" />
                <View style="@style/Stats_SectionDivider" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">
                    <TableRow>
                        <TextView style="@style/TextView" android:text="@string/stat_best_score" />
                        <TextView android:id="@+id/Stats_Snake_BigRecord" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_no_obstacles" />
                        <TextView android:id="@+id/Stats_Snake_BigPlain" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                    <TableRow android:layout_marginTop="10dp">
                        <TextView style="@style/TextView" android:text="@string/stat_obstacles" />
                        <TextView android:id="@+id/Stats_Snake_BigObstacles" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                    </TableRow>
                </TableLayout>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
