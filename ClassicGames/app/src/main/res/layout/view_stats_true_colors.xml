<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/Stats_Hint_Prev"
                style="@style/TextView"
                android:text="@string/swipe_right"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/Stats_Hint_Next"
                style="@style/TextView"
                android:text="@string/swipe_left"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/Stats_TrueColors_Title"
                style="@style/TitleTextView"
                android:layout_marginTop="20dp"
                android:text="@string/true_colors_game"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/Stats_Hint_Next" />

            <ImageView
                android:id="@+id/Stats_TrueColors_Image"
                style="@style/ImageButton_Games"
                android:contentDescription="@string/true_colors_game"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/Stats_TrueColors_Title"
                app:srcCompat="@drawable/true_colors" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:paddingHorizontal="50dp"
                android:stretchColumns="*"
                app:layout_constraintTop_toBottomOf="@+id/Stats_TrueColors_Image">

                <TableRow>
                    <TextView style="@style/TextView" android:text="@string/record" />
                    <TextView android:id="@+id/Stats_TrueColors_Record" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                </TableRow>
                <TableRow android:layout_marginTop="10dp">
                    <TextView style="@style/TextView" android:text="@string/stat_games_played" />
                    <TextView android:id="@+id/Stats_TrueColors_Games" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                </TableRow>
                <TableRow android:layout_marginTop="10dp">
                    <TextView style="@style/TextView" android:text="@string/stat_total_correct" />
                    <TextView android:id="@+id/Stats_TrueColors_TotalCorrect" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                </TableRow>
                <TableRow android:layout_marginTop="10dp">
                    <TextView style="@style/TextView" android:text="@string/stat_best_run" />
                    <TextView android:id="@+id/Stats_TrueColors_BestRun" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                </TableRow>
                <TableRow android:layout_marginTop="10dp">
                    <TextView style="@style/TextView" android:text="@string/stat_average_correct" />
                    <TextView android:id="@+id/Stats_TrueColors_AvgCorrect" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                </TableRow>
                <TableRow android:layout_marginTop="10dp">
                    <TextView style="@style/TextView" android:text="@string/stat_total_points" />
                    <TextView android:id="@+id/Stats_TrueColors_TotalPoints" style="@style/TextView" android:textAlignment="viewEnd" android:text="@string/zero" />
                </TableRow>
            </TableLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
