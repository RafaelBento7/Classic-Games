<?xml version="1.0" encoding="utf-8"?>
<!-- Red frame around the Snake play area. Drawn as a normal View background (the
     game's SurfaceView is inset away from it via the frame's padding) so all four
     sides render at exactly the same width. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="3dp"
        android:color="#D32F2F" />
</shape>
